{
  "name": "jp_web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/ci/run-node-tests.mjs all",
    "test:smoke": "npm run lint && npm run typecheck && node scripts/ci/assert-test-groups.mjs",
    "test:publications": "node scripts/ci/run-node-tests.mjs publications",
    "test:forms": "node scripts/ci/run-node-tests.mjs forms",
    "test:routing-seo": "node scripts/ci/run-node-tests.mjs routingSeo",
    "test:static-pages": "node scripts/ci/run-node-tests.mjs staticPages",
    "test:assets-shell": "node scripts/ci/run-node-tests.mjs assetsShell",
    "test:cross-cutting": "node scripts/ci/run-node-tests.mjs crossCutting",
    "test:ci": "npm run test:smoke && npm run test:publications && npm run test:forms && npm run test:routing-seo && npm run test:static-pages && npm run test:assets-shell && npm run test:cross-cutting",
    "e2e:stage": "npx playwright test tests-local/src/app --config=playwright.local.config.mjs",
    "e2e:local:contact-us:stage": "npx playwright test tests-local/src/app/contact-us/page.e2e.mjs --config=playwright.local.config.mjs",
    "e2e:local:whitepaper-gating:stage": "npx playwright test tests-local/src/app/internal/whitepaper-gating-form/page.e2e.mjs --config=playwright.local.config.mjs",
    "e2e:local:blog:stage": "npx playwright test tests-local/src/app/blog/page.e2e.mjs --config=playwright.local.config.mjs",
    "e2e:local:whitepapers:stage": "npx playwright test tests-local/src/app/whitepapers/page.e2e.mjs --config=playwright.local.config.mjs",
    "e2e:local:whitepaper-pdf:stage": "npx playwright test tests-local/src/app/whitepapers/pdf-page.e2e.mjs --config=playwright.local.config.mjs",
    "e2e:local:news-list:stage": "LOCAL_E2E_BASE_URL=https://stage.querypie.ai npx playwright test tests-local/src/app/news/page.e2e.mjs --config=playwright.local.config.mjs",
    "e2e:local:news-detail:stage": "LOCAL_E2E_BASE_URL=https://stage.querypie.ai npx playwright test tests-local/src/app/news/page.e2e.mjs --config=playwright.local.config.mjs",
    "e2e:local:sitemap:stage": "npx playwright test tests-local/src/app/sitemap/page.e2e.mjs --config=playwright.local.config.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.4",
    "next-mdx-remote-client": "^2.1.10",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.4.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
