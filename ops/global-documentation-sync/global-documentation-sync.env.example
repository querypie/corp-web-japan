GLOBAL_REPO=/srv/repos/corp-web-v2
TARGET_REPO=/srv/repos/corp-web-japan
REPORTS_ROOT=/var/lib/global-documentation-sync/reports
WORKTREES_ROOT=/srv/repos/corp-web-japan-worktrees/global-documentation-sync
TURBOPACK_ROOT=/srv/repos
GITHUB_REPO=querypie/corp-web-japan
PI_BIN=/usr/local/bin/pi
PI_PROVIDER=replace-with-provider
PI_MODEL=replace-with-model
